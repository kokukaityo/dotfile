#!/usr/bin/env bash
# bin/dotfile — dotfile エンジンのエントリポイント
set -euo pipefail

# macOS の readlink -f 非対応を考慮したシンボリックリンク解決
resolve_path() {
    local target="$1"
    while [ -L "$target" ]; do
        local dir
        dir="$(cd "$(dirname "$target")" && pwd)"
        target="$(readlink "$target")"
        [[ "$target" != /* ]] && target="$dir/$target"
    done
    echo "$(cd "$(dirname "$target")" && pwd)"
}

DOTFILE_ENGINE_DIR="$(cd "$(resolve_path "${BASH_SOURCE[0]}")/.." && pwd)"
export DOTFILE_ENGINE_DIR
export DOTFILE_ENGINE_LIB="${DOTFILE_ENGINE_DIR}/lib"

VERSION="$(cat "$DOTFILE_ENGINE_DIR/VERSION" 2>/dev/null || echo "dev")"

# --- init（conf.sh 不要で動く必要がある） ---

cmd_init() {
    local target_dir="${1:-$HOME/dotfile}"
    local template_dir="$DOTFILE_ENGINE_DIR/template"

    if [ ! -d "$template_dir" ]; then
        echo "[dotfile] Error: テンプレートが見つかりません: $template_dir" >&2
        exit 1
    fi

    if [ -e "$target_dir" ]; then
        echo "[dotfile] Error: 既にディレクトリが存在します: $target_dir" >&2
        echo "  別のパスを指定するか、既存のディレクトリを削除してください。" >&2
        exit 1
    fi

    echo "[dotfile] データリポジトリを作成: $target_dir"
    cp -r "$template_dir" "$target_dir"

    cd "$target_dir"
    git init
    git add -A
    git commit -m "feat: initial dotfile setup"

    echo ""
    echo "[dotfile] 初期設定を実行中..."
    export DOTFILE_DIR="$target_dir"
    source "$DOTFILE_ENGINE_LIB/conf.sh"
    cmd_setup

    echo ""
    echo "=== データリポジトリの作成が完了しました ==="
    echo ""
    echo "次のステップ:"
    echo "  1. GitHub に private リポジトリを作成"
    echo "  2. リモートを追加:"
    echo "     cd $target_dir"
    echo "     git remote add origin git@github.com:<user>/<repo>.git"
    echo "     git push -u origin main"
    echo ""
    echo "  3. ~/.bashrc or ~/.zshrc に自動同期を設定:"
    echo "     export DOTFILE_DIR=\"$target_dir\""
    echo "     command -v dotfile >/dev/null && dotfile pull"
    echo "     command -v dotfile >/dev/null && dotfile status"
}

# --- setup（現 setup.sh の内容） ---

cmd_setup() {
    # conf.sh がまだ source されていない場合（init 経由以外での直接呼び出し）
    if [ -z "${DOTFILE:-}" ]; then
        source "$DOTFILE_ENGINE_LIB/conf.sh"
    fi

    cd "$DOTFILE"

    echo "=== dotfile setup ==="
    echo ""

    # 1. Git hook
    git config core.hooksPath "${DOTFILE_ENGINE_LIB}/hook"
    chmod +x "${DOTFILE_ENGINE_LIB}/hook/"* 2>/dev/null || true
    echo "[setup] Git hook configured (core.hooksPath=${DOTFILE_ENGINE_LIB}/hook)"

    # 2. symlink をそのまま保存する設定
    if ! grep -q '^\* -text' .gitattributes 2>/dev/null; then
        echo '* -text' >> .gitattributes
    fi
    git config core.symlinks true
    echo "[setup] .gitattributes configured for symlink"

    # 3. .gitignore 生成
    bash "$DOTFILE_ENGINE_LIB/sync.sh" gitignore

    # 4. symlink 配置
    bash "$DOTFILE_ENGINE_LIB/link.sh"

    echo ""
    echo "=== Setup complete ==="
    echo ""
    echo "シェル起動時の自動同期を設定する場合、~/.bashrc or ~/.zshrc に以下を追加:"
    echo "  export DOTFILE_DIR=\"$DOTFILE\""
    echo "  command -v dotfile >/dev/null && dotfile pull"
    echo "  command -v dotfile >/dev/null && dotfile status"
}

# --- version ---

cmd_version() {
    echo "dotfile engine v${VERSION}"
    echo "  engine: ${DOTFILE_ENGINE_DIR}"
    if [ -n "${DOTFILE:-}" ]; then
        echo "  data:   ${DOTFILE}"
        if [ -f "$DOTFILE/.infra-version" ]; then
            echo "  data version: $(cat "$DOTFILE/.infra-version")"
        fi
    fi
}

# --- help ---

usage() {
    cat <<EOF
dotfile v${VERSION} — dotfile 同期エンジン

Usage: dotfile <command> [option]

Command:
  init [path]        データリポジトリを新規作成（デフォルト: ~/dotfile）
  setup              データリポジトリの初期設定
  link               symlink を配置
  pull               リモートから同期
  push               変更を自動 commit & push
  delete-category    カテゴリを削除
  gitignore          .gitignore を再生成
  status             コンフリクト状態を表示
  version            バージョン情報を表示
  help               このヘルプを表示

EOF
}

# --- main ---

case "${1:-help}" in
    init)
        shift
        cmd_init "$@"
        ;;
    setup)
        source "$DOTFILE_ENGINE_LIB/conf.sh"
        cmd_setup
        ;;
    link)
        bash "$DOTFILE_ENGINE_LIB/link.sh"
        ;;
    pull)
        bash "$DOTFILE_ENGINE_LIB/sync.sh" pull
        ;;
    push)
        bash "$DOTFILE_ENGINE_LIB/sync.sh" push
        ;;
    delete-category)
        shift
        bash "$DOTFILE_ENGINE_LIB/sync.sh" delete-category "$@"
        ;;
    gitignore)
        bash "$DOTFILE_ENGINE_LIB/sync.sh" gitignore
        ;;
    status)
        bash "$DOTFILE_ENGINE_LIB/sync.sh" status
        ;;
    version|--version|-v)
        source "$DOTFILE_ENGINE_LIB/conf.sh" 2>/dev/null || true
        cmd_version
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage
        exit 1
        ;;
esac
